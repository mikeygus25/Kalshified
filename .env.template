# Kalshi API credentials
# Key ID (UUID) from your Kalshi API key settings
KALSHI_API_KEY_ID=your_kalshi_key_id_here
# Absolute path to your RSA private key PEM file (generated when creating the API key)
KALSHI_PRIVATE_KEY_PATH=/path/to/kalshi_private_key.pem

# Anthropic API key (for Claude agents)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Sheets sync (optional — leave blank to disable)
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_ID/exec

# News context for Edge (optional — improves signal quality for high-priority markets)
# Free tier at https://api.search.brave.com — 2,000 queries/month
BRAVE_SEARCH_API_KEY=your_brave_api_key_here

# Telegram trade alerts (optional — get notified on every buy/sell)
# Setup: message @BotFather on Telegram to create a bot, then find your chat_id via getUpdates
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Trading environment: "demo" or "prod" (both now use api.elections.kalshi.com)
KALSHI_ENV=demo

# Risk controls
MAX_POSITION_SIZE=100
MAX_DAILY_LOSS=500
MAX_OPEN_POSITIONS=10

# Robinhood MCP trading agent (optional)
# Obtain via: npx @modelcontextprotocol/inspector → connect https://agent.robinhood.com/mcp/trading → OAuth flow → copy access_token
ROBINHOOD_ACCESS_TOKEN=

# Agent polling intervals (milliseconds)
SCOUT_INTERVAL=60000
EDGE_INTERVAL=30000
VAULT_INTERVAL=10000
ROBINHOOD_INTERVAL=300000

# Server port
PORT=3000

# Dashboard auth (protect your trading controls)
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=changeme
JWT_SECRET=generate-a-long-random-string-here
